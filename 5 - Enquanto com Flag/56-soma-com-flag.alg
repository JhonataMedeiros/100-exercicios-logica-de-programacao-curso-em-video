Algoritmo "SomaComTermino"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 12/05/2026
//Objetivo: LÍ nķmeros do teclado e mostra a soma total, parando ao digitar 1111
Var
   numero, soma: Inteiro
Inicio

   soma <- 0

   Escreval("Obs. Digite 1111 para encerrar")
   Escreva("Digite um nķmero: ")
   Leia(numero)

   Enquanto numero <> 1111 faÁa
      soma <- soma + numero
      Escreval("Digite outro nķmero")
      Leia(numero)
   fimEnquanto

   Escreval("Soma total: ", soma)

Fimalgoritmo