Algoritmo "67891011Acabou"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 09/05/2026
//Objetivo: Mostrar uma sequęncia de números específicos na tela
Var
   Contador, numero: Inteiro
Inicio

   Contador <- 0
   numero <- 6

   Enquanto Contador <= 5 faça
      Escreva(numero)
      numero <- numero + 1
      Contador <- Contador + 1
   fimEnquanto

   Escreva(" Acabou!")

Fimalgoritmo