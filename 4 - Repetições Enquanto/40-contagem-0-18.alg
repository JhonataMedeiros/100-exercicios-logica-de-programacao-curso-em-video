Algoritmo "0369121518Acabou!"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 04/05/2026
//Objetivo: Mostrar uma sequęncia de números específicos na tela
Var
   Contador, numero: Inteiro
Inicio

   Contador <- 0
   numero <- 0

   Enquanto Contador <= 6 faça
      Escreva(numero)
      numero <- numero + 3
      Contador <- Contador + 1
   fimEnquanto

   Escreva(" Acabou!")

Fimalgoritmo