Algoritmo "ContadorRegressivo"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 04/05/2026
//Objetivo: Mostrar uma sequęncia regressiva passo 5
var
   contador: inteiro
inicio

   contador <- 100

   enquanto (contador >= 0) faça
      Escreva (contador)
      contador <- contador - 5
   fimenquanto

   Escreva (" Acabou!")

fimalgoritmo