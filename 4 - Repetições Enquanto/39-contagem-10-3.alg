Algoritmo "109876543Acabou!"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 04/05/2026
//Objetivo: Mostrar uma sequęncia de números específicos na tela
Var
   Contador, numero: Inteiro
Inicio

   Contador <- 0
   numero <- 10

   Enquanto Contador <= 7 faça
      Escreva(numero)
      numero <- numero - 1
      Contador <- Contador + 1
   fimEnquanto

   Escreva(" Acabou!")

Fimalgoritmo