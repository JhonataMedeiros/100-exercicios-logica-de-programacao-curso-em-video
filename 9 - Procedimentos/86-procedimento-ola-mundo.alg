Algoritmo "ProcedimentoOlaMundo"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 01/06/2026
//Objetivo: Escrever a mensagem "Olá, Mundo" usando procedimento
Var

procedimento gerador()
inicio

   Escreval("+-------=======------+")
   Escreval("Olá, Mundo")
   Escreval("+-------=======------+")
fimprocedimento

Inicio

   gerador()

Fimalgoritmo