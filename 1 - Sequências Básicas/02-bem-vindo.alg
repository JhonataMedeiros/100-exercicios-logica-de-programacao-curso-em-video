Algoritmo "BemVindo"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 02/05/2026
//Objetivo: Exibir uma mensagem de boas-vindas
Var
   nome: Caractere
Inicio

   Escreva("Digite seu nome: ")
   Leia(nome)

   limpaTela

   Escreval("=====================================")
   Escreval("Ol· ", nome, ", seja muito bem-vindo(a)")
   Escreval("=====================================")
   
Fimalgoritmo