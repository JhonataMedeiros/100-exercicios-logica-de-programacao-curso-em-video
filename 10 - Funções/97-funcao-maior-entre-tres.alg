Algoritmo "EncontrarMaior"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 07/06/2026
//Objetivo: Passar tręs números para uma funçăo que
//          irá verificar qual número é o maior ou se săo iguais
Var
   primeiroValor, segundoValor, terceiroValor, Resultado: Inteiro

Funçăo Maior(primeiroNumero, segundoNumero, terceiroNumero: Inteiro): Inteiro
Var
   maiorValor: Inteiro
Inicio

   maiorValor <- primeiroNumero

   Se segundoNumero > maiorValor entăo
      maiorValor <- segundoNumero
   FimSe

   Se terceiroNumero > maiorValor entăo
      maiorValor <- terceiroNumero
   FimSe

   Retorne maiorValor

FimFunçăo

Inicio

   Escreva("Digite o primeiro número: ")
   Leia(primeiroValor)
   Escreva("Digite o segundo número: ")
   Leia(segundoValor)
   Escreva("Digite o terceiro número: ")
   Leia(terceiroValor)

   Resultado <- Maior(primeiroValor, segundoValor, terceiroValor)
   Escreval("--------------------------------------")
   Escreval("O maior número digitado foi: ", Resultado)

Fimalgoritmo