Algoritmo "Matriz3x3"
//Autoria: Jhonata Medeiros Moreira
//Data: 12/06/2026
//Objetivo: Preencher uma Matriz 3x3 com valores via teclado
Var
   Valor: Vetor[1..3, 1..3] de Inteiro
   Linha, Coluna: Inteiro
Inicio

   Para Linha <- 1 atķ 3 fańa
      Para Coluna <- 1 atķ 3 fańa
         Escreva("Digite o n·mero da posińŃo [", Linha, ",", Coluna, "] : ")
         Leia(Valor[Linha,Coluna])
      fimPara
   fimPara

   limpaTela

   Para Linha <- 1 atķ 3 fańa
      Para Coluna <- 1 atķ 3 fańa
         Escreva("[", Valor[Linha,Coluna], " ]")
      fimPara
      Escreval()
   fimPara

Fimalgoritmo