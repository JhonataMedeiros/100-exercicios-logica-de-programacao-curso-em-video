Algoritmo "PA"
//Autoria: Jhonata Medeiros Moreira
//Data atual: 19/05/2026
//Objetivo: mostrar na tela os 10 primeiros elementos da PA e
//          a soma entre todos os valores da sequÍncia
Var
   Contador, primeiroTermo, termoAtual, razao, soma: Inteiro
Inicio

   Escreval("Digite qual ser· o primeiro termo: ")
   Leia(primeiroTermo)

   Escreval("Digite qual ser· a raz„o: ")
   Leia(razao)

   limpaTela

   soma <- 0
   termoAtual <- primeiroTermo

   Para Contador de 1 atÈ 10 faÁa
      Escreva(termoAtual, " ")
      soma <- soma + termoAtual
      termoAtual <- termoAtual + razao
   fimPara

   Escreval(" ")
   Escreval("'''''''''''''''""''''''''''''''''''''''''")
   Escreval("Soma entre todos os termos: ", soma)

Fimalgoritmo